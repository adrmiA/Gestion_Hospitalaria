<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="sv.hospital.gestionhospitalaria.controller.medico.MedicoDashboardController">

    <!-- SIDEBAR -->
    <left>
        <VBox styleClass="sidebar" prefWidth="220" spacing="0">
            <Label fx:id="lblNombre" text="Dr. Nombre" styleClass="sidebar-title"/>
            <Label text="Médico" styleClass="sidebar-subtitle"/>
            <Separator style="-fx-background-color:#2d5986;"/>
            <Button text="🏠  Inicio" styleClass="menu-btn,menu-btn-active"
                    onAction="#showDashboard" fx:id="btnInicio"/>
            <Button text="📅  Mis Citas" styleClass="menu-btn"
                    onAction="#showCitas" fx:id="btnCitas"/>
            <Button text="🩺  Consultas" styleClass="menu-btn"
                    onAction="#showConsultas" fx:id="btnConsultas"/>
            <Button text="🧪  Laboratorio" styleClass="menu-btn"
                    onAction="#showLaboratorio" fx:id="btnLaboratorio"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Button text="🚪  Cerrar Sesión" styleClass="menu-logout"
                    onAction="#handleLogout"/>
        </VBox>
    </left>

    <!-- MAIN CONTENT -->
    <center>
        <StackPane fx:id="contentArea" styleClass="content-pane"/>
    </center>
</BorderPane>