<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="sv.hospital.gestionhospitalaria.controller.recepcion.RecepcionDashboardController">
    <left>
        <VBox styleClass="sidebar" prefWidth="220">
            <Label fx:id="lblNombre" text="Recepción" styleClass="sidebar-title"/>
            <Label text="Recepcionista" styleClass="sidebar-subtitle"/>
            <Separator style="-fx-background-color:#2d5986;"/>
            <Button text="👥  Pacientes"      styleClass="menu-btn" onAction="#showPacientes"   fx:id="btnPacientes"/>
            <Button text="📅  Citas"           styleClass="menu-btn" onAction="#showCitas"       fx:id="btnCitas"/>
            <Button text="🏥  Hospitalización" styleClass="menu-btn" onAction="#showHospitalizacion" fx:id="btnHosp"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Button text="🚪  Cerrar Sesión" styleClass="menu-logout" onAction="#handleLogout"/>
        </VBox>
    </left>
    <center>
        <StackPane fx:id="contentArea" styleClass="content-pane"/>
    </center>
</BorderPane>